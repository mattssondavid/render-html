{
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": false,
        "esModuleInterop": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "dist-node",
        "removeComments": true,
        "rewriteRelativeImportExtensions": true,
        "rootDir": ".",
        "skipLibCheck": true,
        "strict": true,
        "target": "esnext"
    },
    "include": ["src", "node.ts", "shim.ts"]
}
